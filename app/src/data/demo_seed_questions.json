    "examProgram": "nclex-pn",
    "itemType": "multiple_choice",
    "stem": "A client using axillary crutches asks where body weight should be placed. Which teaching is correct?",
    "choices": [
      "Support body weight through the hand grips.",
      "Rest body weight in the axillae.",
      "Remove the rubber tips for smoother movement.",
      "Keep elbows locked while walking."
    ],
    "correctAnswerIndexes": [0],
    "correctAnswerText": ["Support body weight through the hand grips."],
    "rationale": "Weight should be borne through the hands. Axillary pressure can cause nerve injury, and rubber tips support traction.",
    "whyWrong": [
      "Axillary pressure can injure nerves and blood vessels.",
      "Rubber tips reduce fall risk.",
      "Locked elbows reduce control and shock absorption."
    ],
