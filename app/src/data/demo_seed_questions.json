    "examProgram": "nclex-pn",
    "itemType": "multiple_choice",
    "stem": "A client with low vision is served breakfast. Which action best supports independent eating?",
    "choices": [
      "Describe the food locations using clock positions.",
      "Ask the client to identify each food by touch.",
      "Mix all foods together so the plate is easier to manage.",
      "Explain the food groups represented on the tray."
    ],
    "correctAnswerIndexes": [0],
    "correctAnswerText": ["Describe the food locations using clock positions."],
    "rationale": "Clock positions give a consistent spatial reference and help the client locate food without relying on vision.",
    "whyWrong": [
      "Touching food is not the preferred first approach.",
      "Mixing foods reduces choice and dignity.",
      "Food-group teaching does not orient the client to the plate."
    ],
